Soma de Números em um Array: Faça um programa que leia 5 números inteiros, armazene-os em um array e calcule a soma total desses números.

#include <stdio.h>

int main(){
    int array[5];
    int soma=0;
    int i;
    printf("Digite 5 números: ");
    for (i=0; i<5; i++){
        scanf("%d", &array[5]);
        soma += array[5];
    }
    printf("A soma é %d.", soma);
    return 0;
}
