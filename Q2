#include <stdio.h>

int fatorial(int n){
    if(n == 0 || n == 1)
        return 1;
    else
        return n*fatorial(n-1);
}

int main(){
    
    int N;
    printf("Digite um número inteiro. ");
    scanf("%d", &N);
    printf("O fatorial desse número é: ");
    printf("%d", fatorial(N));
    
    return 0;
}
