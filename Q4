Conversão de Temperatura: Escreva um programa que converta uma temperatura fornecida em graus Celsius para Fahrenheit e vice-versa.

#include <stdio.h>

float CtoF(float c) {
    return (c * 1.8) + 32;
}

float FtoC(float f) {
    return (f - 32) * 5/9;
}

int main() {
    float temp;
    int conv;
    printf("Qual conversão deseja fazer?:\n");
    printf("1 - Celsius para Fahrenheit\n");
    printf("2 - Fahrenheit para Celsius\n");
    scanf("%d", &conv);

    if(conv == 1) {
        printf("Digite a temperatura em Celsius: ");
        scanf("%f", &temp);
        printf("Temperatura em Fahrenheit após conversão: %.2f\n", CtoF(temp));
    }
    else if(conv == 2) {
        printf("Digite a temperatura em Fahrenheit: ");
        scanf("%f", &temp);
        printf("Temperatura em Celsius após conversão: %.2f\n", FtoC(temp));
    }
    else {
        printf("Não existe opção para o número digitado");
    }
    return 0;
}
