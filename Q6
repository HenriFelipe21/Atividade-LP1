Verificação de Número Primo: Desenvolva um programa que leia um número inteiro e determine se ele é um número primo ou não.

#include <stdio.h>
#include <math.h>

int main() {
    int n;
    int i;
    printf("Digite um número inteiro: ");
    scanf("%d", &n);
    
    if (n < 1){
        printf("Números menores que 1 não são primos.");
    }else if (n == 1){
        printf("1 é primo.");
    }else if (n > 1){
        for (i = 2; i <= sqrt(n); i++);
            if (n % i==0){
                printf("%d não é primo.", n);
            }else{
                printf("%d é primo.", n);
            }
    }
    return 0;
}
