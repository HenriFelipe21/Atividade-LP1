Impressão de Números de 1 a N: Escreva um programa que leia um número inteiro positivo N e imprima todos os números de 1 até N.

#include <stdio.h>

int main() {
    int N;
    int i;
    printf("Digite um número inteiro. ");
    scanf("%d", &N);
    printf("Os números de 1 até %d são: \n", N);

    for(i = 1; i <= N; i++) {
        printf("%d\n", i);
    }
    return 0;
}
